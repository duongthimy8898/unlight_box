{
  "name": "bunny-upload-server",
  "version": "1.0.0",
  "description": "Express TypeScript server upload video to Bunny Stream + Storage",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@bunny.net/storage-sdk": "^0.3.1",
    "@types/cors": "^2.8.19",
    "axios": "^1.14.0",
    "busboy": "^1.6.0",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "dotenv-flow": "^4.1.0",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.39",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
